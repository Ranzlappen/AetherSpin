{
  "name": "@aetherspin/frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Production web client for the NovaForged Stake Engine slot.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,svelte}\" --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
