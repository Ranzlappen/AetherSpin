{
  "name": "aetherspin",
  "version": "1.0.0",
  "private": true,
  "description": "AetherSpin — a production-grade Stake Engine game studio monorepo. Reusable math + web engine scaffold plus the flagship NovaForged slot.",
  "license": "MIT",
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,svelte,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,svelte,js,json,md}\"",
    "math:simulate": "python3 math/scripts/simulate.py",
    "math:validate": "python3 math/scripts/validate_rtp.py",
    "math:books": "python3 math/scripts/generate_books.py",
    "package:stake": "bash scripts/package-for-stake.sh",
    "setup:math": "bash scripts/setup-math.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^4.1.1",
    "turbo": "^2.1.0"
  }
}
